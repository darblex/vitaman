# ─── VITAMAN Bot Configuration ───
# Copy this file to .env and fill in your values

# Telegram Bot
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
SELLER_CHAT_ID=YOUR_SELLER_CHAT_ID
SELLER_USERNAME=YOUR_SELLER_USERNAME
WHATSAPP_NUMBER=YOUR_WHATSAPP_NUMBER

# Facebook Marketing API
FB_PAGE_ACCESS_TOKEN=YOUR_PAGE_ACCESS_TOKEN
FB_PAGE_ID=YOUR_PAGE_ID
FB_AD_ACCOUNT_ID=act_XXXXXXXXX
FB_APP_ID=YOUR_APP_ID
FB_APP_SECRET=YOUR_APP_SECRET

# Facebook Pixel (for Conversions API)
FB_PIXEL_ID=YOUR_PIXEL_ID
FB_CAPI_TOKEN=YOUR_CONVERSIONS_API_TOKEN

# Bot Settings
REMINDER_DELAY_SECONDS=3600
MAX_QTY=5
DISCOUNT_THRESHOLD=3
DISCOUNT_PCT=10

# Landing Page URL (for Facebook ads)
LANDING_PAGE_URL=https://your-domain.com
TELEGRAM_BOT_URL=https://t.me/your_bot
